{
  "name": "oxgraph-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build-napi": "napi build --cwd ../../ -p oxgraph --features napi --no-js",
    "build-napi-release": "napi build --cwd ../../ -p oxgraph --release --features napi --no-js",
    "build-js": "tsdown src-js/index.ts src-js/cli.ts --format esm --dts --out-dir ../../npm/oxgraph/dist",
    "build": "pnpm build-napi && pnpm build-js && cargo run --bin generate_schemas"
  },
  "devDependencies": {
    "@napi-rs/cli": "catalog:",
    "tsdown": "catalog:",
    "vitest": "catalog:"
  }
}
