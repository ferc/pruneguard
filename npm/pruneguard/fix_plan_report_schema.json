{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FixPlanReport",
  "description": "Fix plan report for agent-driven remediation workflows.",
  "type": "object",
  "required": [
    "actions",
    "confidence",
    "highConfidenceActions",
    "matchedFindings",
    "query",
    "riskLevel",
    "totalActions"
  ],
  "properties": {
    "actions": {
      "description": "Ordered remediation actions (ranked: high confidence first, low blast radius first, dead-code before architecture churn).",
      "type": "array",
      "items": {
        "$ref": "#/definitions/RemediationAction"
      }
    },
    "blockedBy": {
      "description": "Reasons why some findings could not produce actions.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "description": "Overall confidence (the minimum across all matched findings).",
      "allOf": [
        {
          "$ref": "#/definitions/FindingConfidence"
        }
      ]
    },
    "highConfidenceActions": {
      "description": "Number of actions that are high confidence.",
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "matchedFindings": {
      "description": "Findings matched by the query.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/Finding"
      }
    },
    "phaseSummary": {
      "description": "Summary of actions by phase.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/FixPlanPhase"
      }
    },
    "query": {
      "description": "The query targets that were searched for.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "riskLevel": {
      "description": "Overall risk level (the maximum across all actions).",
      "allOf": [
        {
          "$ref": "#/definitions/RiskLevel"
        }
      ]
    },
    "totalActions": {
      "description": "Total number of actions in the plan.",
      "type": "integer",
      "format": "uint",
      "minimum": 0.0
    },
    "verificationSteps": {
      "description": "Top-level verification steps to run after the entire plan is applied.",
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "definitions": {
    "Evidence": {
      "description": "Evidence supporting a finding.",
      "type": "object",
      "required": [
        "description",
        "kind"
      ],
      "properties": {
        "description": {
          "description": "Description of this evidence.",
          "type": "string"
        },
        "file": {
          "description": "File path involved.",
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "description": "Type of evidence.",
          "type": "string"
        },
        "line": {
          "description": "Line number, if applicable.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        }
      }
    },
    "Finding": {
      "description": "A single finding from analysis.",
      "type": "object",
      "required": [
        "category",
        "code",
        "confidence",
        "id",
        "message",
        "severity",
        "subject"
      ],
      "properties": {
        "actionKinds": {
          "description": "All applicable remediation action kinds.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/RemediationActionKind"
          }
        },
        "category": {
          "description": "Category of the finding.",
          "allOf": [
            {
              "$ref": "#/definitions/FindingCategory"
            }
          ]
        },
        "code": {
          "description": "Machine-readable code (e.g. `unused-export`, `cycle`, `boundary-violation`).",
          "type": "string"
        },
        "confidence": {
          "description": "Confidence level for this finding.",
          "allOf": [
            {
              "$ref": "#/definitions/FindingConfidence"
            }
          ]
        },
        "confidenceReason": {
          "description": "Human-readable reason for the confidence level assigned to this finding.",
          "type": [
            "string",
            "null"
          ]
        },
        "evidence": {
          "description": "Evidence supporting the finding.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/Evidence"
          }
        },
        "frameworkContext": {
          "description": "Framework context relevant to this finding.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "id": {
          "description": "Stable deterministic ID for this finding.",
          "type": "string"
        },
        "message": {
          "description": "Human-readable message.",
          "type": "string"
        },
        "package": {
          "description": "Package this finding belongs to, if applicable.",
          "type": [
            "string",
            "null"
          ]
        },
        "precisionSource": {
          "description": "Source of precision for this finding's evidence.",
          "anyOf": [
            {
              "$ref": "#/definitions/PrecisionSource"
            },
            {
              "type": "null"
            }
          ]
        },
        "primaryActionKind": {
          "description": "Primary remediation action kind for this finding.",
          "anyOf": [
            {
              "$ref": "#/definitions/RemediationActionKind"
            },
            {
              "type": "null"
            }
          ]
        },
        "ruleName": {
          "description": "Name of the rule that produced this finding, if any.",
          "type": [
            "string",
            "null"
          ]
        },
        "severity": {
          "description": "Severity level.",
          "allOf": [
            {
              "$ref": "#/definitions/FindingSeverity"
            }
          ]
        },
        "subject": {
          "description": "The subject of the finding (file path, export name, etc.).",
          "type": "string"
        },
        "suggestion": {
          "description": "Suggested fix.",
          "type": [
            "string",
            "null"
          ]
        },
        "trustNotes": {
          "description": "Trust-related notes for this finding.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "workspace": {
          "description": "Workspace this finding belongs to, if applicable.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "FindingCategory": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "unused-export",
            "unused-file",
            "unused-package",
            "unused-dependency",
            "cycle",
            "boundary-violation",
            "ownership-violation",
            "impact"
          ]
        },
        {
          "description": "An exported class member, enum variant, or namespace member is unused.",
          "type": "string",
          "enum": [
            "unused-member"
          ]
        },
        {
          "description": "The same symbol is exported from multiple paths (barrel re-export collision).",
          "type": "string",
          "enum": [
            "duplicate-export"
          ]
        }
      ]
    },
    "FindingConfidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "FindingSeverity": {
      "type": "string",
      "enum": [
        "error",
        "warn",
        "info"
      ]
    },
    "FixPlanPhase": {
      "description": "A phase in a fix plan, grouping related actions.",
      "type": "object",
      "required": [
        "actionCount",
        "description",
        "name",
        "order"
      ],
      "properties": {
        "actionCount": {
          "description": "Number of actions in this phase.",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "description": {
          "description": "Description of what this phase addresses.",
          "type": "string"
        },
        "name": {
          "description": "Phase name.",
          "type": "string"
        },
        "order": {
          "description": "Phase ordering number (lower = earlier).",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        }
      }
    },
    "PrecisionSource": {
      "description": "Source of the precision for a finding's evidence.",
      "oneOf": [
        {
          "description": "Rust static analysis only.",
          "type": "string",
          "enum": [
            "rust-static"
          ]
        },
        {
          "description": "Derived from framework-generated source maps or .d.ts files.",
          "type": "string",
          "enum": [
            "generated-map"
          ]
        },
        {
          "description": "Derived from framework config file extraction.",
          "type": "string",
          "enum": [
            "config-derived"
          ]
        },
        {
          "description": "Refined by the semantic helper binary.",
          "type": "string",
          "enum": [
            "semantic-helper"
          ]
        }
      ]
    },
    "RemediationAction": {
      "description": "A remediation action describing how to fix one or more findings.",
      "type": "object",
      "required": [
        "confidence",
        "id",
        "kind",
        "risk",
        "targets",
        "why"
      ],
      "properties": {
        "confidence": {
          "description": "Confidence in this action's correctness.",
          "allOf": [
            {
              "$ref": "#/definitions/FindingConfidence"
            }
          ]
        },
        "findingIds": {
          "description": "IDs of findings this action addresses.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "id": {
          "description": "Unique identifier for this action.",
          "type": "string"
        },
        "kind": {
          "description": "The kind of remediation to perform.",
          "allOf": [
            {
              "$ref": "#/definitions/RemediationActionKind"
            }
          ]
        },
        "phase": {
          "description": "Phase this action belongs to (dead-code, architecture, governance).",
          "type": [
            "string",
            "null"
          ]
        },
        "preconditions": {
          "description": "Conditions that must be true before this action can be applied.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rank": {
          "description": "Ranking position within the plan (1-based, lower = do first).",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        },
        "risk": {
          "description": "Risk level of this action.",
          "allOf": [
            {
              "$ref": "#/definitions/RiskLevel"
            }
          ]
        },
        "steps": {
          "description": "Ordered steps to execute.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/RemediationStep"
          }
        },
        "targets": {
          "description": "Files or exports this action targets.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verification": {
          "description": "Verification commands to run after applying the action.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "why": {
          "description": "Human-readable rationale explaining why this action is needed.",
          "type": "string"
        }
      }
    },
    "RemediationActionKind": {
      "description": "The kind of remediation action to take.",
      "type": "string",
      "enum": [
        "delete-file",
        "delete-export",
        "remove-dependency",
        "break-cycle",
        "move-import",
        "tighten-entrypoint",
        "update-boundary-rule",
        "assign-owner",
        "split-package",
        "acknowledge-baseline"
      ]
    },
    "RemediationStep": {
      "description": "A single step in a remediation action.",
      "type": "object",
      "required": [
        "description"
      ],
      "properties": {
        "action": {
          "type": [
            "string",
            "null"
          ]
        },
        "description": {
          "type": "string"
        },
        "file": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "RiskLevel": {
      "description": "Risk level for a remediation action or fix plan.",
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}