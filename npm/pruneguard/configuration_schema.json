    "IgnoreIssueRule": {
      "description": "Rule for suppressing specific finding kinds.",
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "codes": {
          "description": "Additional finding codes to match (beyond the primary `kind`).",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "comment": {
          "description": "Optional comment explaining why this is suppressed.",
          "type": [
            "string",
            "null"
          ]
        },
        "files": {
          "description": "Optional glob patterns — only suppress in matching files.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "kind": {
          "description": "The finding kind to suppress (e.g. \"unusedExport\", \"unusedFile\", \"cycle\").",
          "type": "string"
        },
        "packages": {
          "description": "Package names to scope this rule to.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "parentSymbols": {
          "description": "Parent symbol names to scope this rule to.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "symbols": {
          "description": "Symbol names to scope this rule to.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workspaces": {
          "description": "Workspace names to scope this rule to.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "OverrideConfig": {
      "type": "object",
      "properties": {
        "analysis": {
          "description": "Analysis overrides.",
          "anyOf": [
            {
              "$ref": "#/definitions/AnalysisConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "entrypoints": {
          "description": "Entrypoint overrides.",
          "anyOf": [
            {
              "$ref": "#/definitions/EntrypointsConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "files": {
          "description": "File globs this override applies to.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ignore_patterns": {
          "description": "Additional ignore patterns.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "description": "Deterministic tags applied to matching files/workspaces.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workspaces": {
          "description": "Workspace names this override applies to.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "OwnershipConfig": {
      "type": "object",
      "properties": {
        "importCodeowners": {
          "default": false,
          "type": "boolean"
        },
        "teams": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "$ref": "#/definitions/TeamConfig"
          }
        },
        "unownedSeverity": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        }
      }
    },
    "PackageManager": {
      "type": "string",
      "enum": [
        "auto",
        "pnpm",
        "npm",
        "yarn",
        "bun"
      ]
    },
    "ProfilesConfig": {
      "type": "object",
      "properties": {
        "all": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "development": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "production": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ResolverConfig": {
      "type": "object",
      "properties": {
        "conditions": {
          "description": "Export conditions to use when resolving package exports.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "detectBabelAliases": {
          "description": "Whether to detect Babel alias patterns.",
          "default": true,
          "type": "boolean"
        },
        "detectImportEquals": {
          "description": "Whether to detect TypeScript `import =` statements.",
          "default": true,
          "type": "boolean"
        },
        "detectImportMetaGlob": {
          "description": "Whether to detect `import.meta.glob()` calls.",
          "default": true,
          "type": "boolean"
        },
        "detectImportMetaResolve": {
          "description": "Whether to detect `import.meta.resolve()` calls.",
          "default": true,
          "type": "boolean"
        },
        "detectJsdocImports": {
          "description": "Whether to detect `JSDoc` `@import` tags.",
          "default": true,
          "type": "boolean"
        },
        "detectRequireContext": {
          "description": "Whether to detect `require.context()` calls.",
          "default": true,
          "type": "boolean"
        },
        "detectRequireResolve": {
          "description": "Whether to detect `require.resolve()` calls.",
          "default": true,
          "type": "boolean"
        },
        "detectTripleSlash": {
          "description": "Whether to detect triple-slash reference directives.",
          "default": true,
          "type": "boolean"
        },
        "detectTypeImports": {
          "description": "Whether to detect type-only imports.",
          "default": true,
          "type": "boolean"
        },
        "detectUrlConstructor": {
          "description": "Whether to detect `new URL()` constructor patterns.",
          "default": true,
          "type": "boolean"
        },
        "detectWebpackAliases": {
          "description": "Whether to detect webpack alias patterns.",
          "default": true,
          "type": "boolean"
        },
        "extensions": {
          "description": "File extensions to resolve.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preserveSymlinks": {
          "description": "Whether to preserve symlinks during resolution.",
          "default": false,
          "type": "boolean"
        },
        "respectExports": {
          "description": "Whether to respect the `exports` field in package.json.",
          "default": true,
          "type": "boolean"
        },
        "tsconfig": {
          "description": "Paths to tsconfig files.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "Rule": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "comment": {
          "type": [
            "string",
            "null"
          ]
        },
        "from": {
          "anyOf": [
            {
              "$ref": "#/definitions/RuleFilter"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "severity": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "to": {
          "anyOf": [
            {
              "$ref": "#/definitions/RuleFilter"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "RuleFilter": {
      "type": "object",
      "properties": {
        "dependencyKinds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "entrypointKinds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "package": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "packageNot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "path": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pathNot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "profiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reachableFrom": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "reaches": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "tag": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tagNot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workspace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workspaceNot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "RulesConfig": {
      "type": "object",
      "properties": {
        "allow": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Rule"
          }
        },
        "forbidden": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Rule"
          }
        },
        "required": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Rule"
          }
        }
      }
    },
    "SemanticConfig": {
      "description": "Configuration for the optional semantic precision layer.",
      "type": "object",
      "properties": {
        "maxColdOverheadPct": {
          "description": "Maximum percentage of cold-scan overhead the helper is allowed to add (0-100).",
          "default": 20,
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "maxFilesPerQueryBatch": {
