{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PruneguardConfig",
  "description": "Top-level configuration for pruneguard.",
  "type": "object",
  "properties": {
    "$schema": {
      "description": "JSON Schema reference.",
      "type": [
        "string",
        "null"
      ]
    },
    "analysis": {
      "description": "Analysis severity levels.",
      "default": {
        "unusedExports": "warn",
        "unusedFiles": "warn",
        "unusedPackages": "warn",
        "unusedDependencies": "warn",
        "cycles": "warn",
        "boundaries": "warn",
        "ownership": "warn",
        "impact": "warn",
        "unusedMembers": "warn",
        "duplicateExports": "warn",
        "ignoreExportsUsedInFile": false,
        "memberWriteOnlyIsUnused": true
      },
      "allOf": [
        {
          "$ref": "#/definitions/AnalysisConfig"
        }
      ]
    },
    "entrypoints": {
      "description": "Entrypoint configuration.",
      "default": {
        "auto": true,
        "includeTests": false,
        "includeStories": false,
        "includeEntryExports": false
      },
      "allOf": [
        {
          "$ref": "#/definitions/EntrypointsConfig"
        }
      ]
    },
    "extends": {
      "description": "Configs to extend from.",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "frameworks": {
      "description": "Framework detection packs.",
      "anyOf": [
        {
          "$ref": "#/definitions/FrameworksConfig"
        },
        {
          "type": "null"
        }
      ]
    },
    "ignoreIssues": {
      "description": "Suppress specific finding kinds from the report.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/IgnoreIssueRule"
      }
    },
    "ignorePatterns": {
      "description": "Glob patterns for files to ignore entirely.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "overrides": {
      "description": "Per-path or per-workspace overrides.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/OverrideConfig"
      }
    },
    "ownership": {
      "description": "Code ownership configuration.",
      "anyOf": [
        {
          "$ref": "#/definitions/OwnershipConfig"
        },
        {
          "type": "null"
        }
      ]
    },
    "resolver": {
      "description": "Module resolver configuration.",
      "default": {
        "respectExports": true,
        "preserveSymlinks": false,
        "detectRequireResolve": true,
        "detectImportMetaResolve": true,
        "detectImportMetaGlob": true,
        "detectRequireContext": true,
        "detectUrlConstructor": true,
        "detectJsdocImports": true,
        "detectTripleSlash": true,
        "detectImportEquals": true,
        "detectTypeImports": true,
        "detectWebpackAliases": true,
        "detectBabelAliases": true
      },
      "allOf": [
        {
          "$ref": "#/definitions/ResolverConfig"
        }
      ]
    },
    "rules": {
      "description": "Custom rules.",
      "anyOf": [
        {
          "$ref": "#/definitions/RulesConfig"
        },
        {
          "type": "null"
        }
      ]
    },
    "semantic": {
      "description": "Semantic precision layer configuration.",
      "default": {
        "mode": "auto",
        "maxColdOverheadPct": 20,
        "maxFilesPerQueryBatch": 128,
        "maxProjectRefs": 8,
        "maxHelperWallMs": 1200,
        "minUncertaintyScore": 60
      },
      "allOf": [
        {
          "$ref": "#/definitions/SemanticConfig"
        }
      ]
    },
    "workspaces": {
      "description": "Workspace configuration.",
      "anyOf": [
        {
          "$ref": "#/definitions/WorkspacesConfig"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "AnalysisConfig": {
      "type": "object",
      "properties": {
        "boundaries": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "cycles": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "duplicateExports": {
          "description": "Report duplicate exports (same symbol re-exported from multiple paths).",
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "ignoreExportsUsedInFile": {
          "description": "When true, exports consumed only within the same file are still reported as unused.",
          "default": false,
          "type": "boolean"
        },
        "ignoreMembers": {
          "description": "Glob patterns for member names to ignore in unused-member analysis.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "impact": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "memberWriteOnlyIsUnused": {
          "description": "Whether write-only member references count as \"used\". When true (default), a member that is only written to (e.g. `obj.field = x`) but never read is reported as unused.",
          "default": true,
          "type": "boolean"
        },
        "ownership": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "publicTagNames": {
          "description": "`JSDoc` tag names that mark a member as public/intentionally exported. When empty, `@public` is used as the default.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unusedDependencies": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "unusedExports": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "unusedFiles": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "unusedMembers": {
          "description": "Report unused exported class/enum members (methods, properties, variants).",
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "unusedPackages": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        }
      }
    },
    "AnalysisSeverity": {
      "description": "Severity level for analysis features.",
      "type": "string",
      "enum": [
        "off",
        "info",
        "warn",
        "error"
      ]
    },
    "EntrypointsConfig": {
      "type": "object",
      "properties": {
        "auto": {
          "description": "Auto-detect entrypoints from package.json and conventions.",
          "default": true,
          "type": "boolean"
        },
        "exclude": {
          "description": "Exclude entrypoints matching these globs.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "include": {
          "description": "Additional entrypoint globs.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "includeEntryExports": {
          "description": "When true, runtime entrypoint exports are eligible to be reported as unused.  By default (`false`), only public-API entrypoint exports are checked.",
          "default": false,
          "type": "boolean"
        },
        "includeStories": {
          "description": "Whether to include story files as entrypoints.",
          "default": false,
          "type": "boolean"
        },
        "includeTests": {
          "description": "Whether to include test files as entrypoints.",
          "default": false,
          "type": "boolean"
        },
        "profiles": {
          "description": "Profile-specific entrypoint overrides.",
          "anyOf": [
            {
              "$ref": "#/definitions/ProfilesConfig"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "FrameworkToggle": {
      "type": "string",
      "enum": [
        "off",
        "auto",
        "on"
      ]
    },
    "FrameworksConfig": {
      "type": "object",
      "properties": {
        "angular": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "astro": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "babel": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
