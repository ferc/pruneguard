            },
            {
              "type": "null"
            }
          ]
        },
        "jest": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "next": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "nitro": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "nuxt": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "nx": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "parcel": {
          "anyOf": [
