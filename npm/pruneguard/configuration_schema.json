{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PruneguardConfig",
  "description": "Top-level configuration for pruneguard.",
  "type": "object",
  "properties": {
    "$schema": {
      "description": "JSON Schema reference.",
      "type": [
        "string",
        "null"
      ]
    },
    "analysis": {
      "description": "Analysis severity levels.",
      "default": {
        "unusedExports": "warn",
        "unusedFiles": "warn",
        "unusedPackages": "warn",
        "unusedDependencies": "warn",
        "cycles": "warn",
        "boundaries": "warn",
        "ownership": "warn",
        "impact": "warn"
      },
      "allOf": [
        {
          "$ref": "#/definitions/AnalysisConfig"
        }
      ]
    },
    "entrypoints": {
      "description": "Entrypoint configuration.",
      "default": {
        "auto": true,
        "includeTests": false,
        "includeStories": false
      },
      "allOf": [
        {
          "$ref": "#/definitions/EntrypointsConfig"
        }
      ]
    },
    "extends": {
      "description": "Configs to extend from.",
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "frameworks": {
      "description": "Framework detection packs.",
      "anyOf": [
        {
          "$ref": "#/definitions/FrameworksConfig"
        },
        {
          "type": "null"
        }
      ]
    },
    "ignorePatterns": {
      "description": "Glob patterns for files to ignore entirely.",
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "overrides": {
      "description": "Per-path or per-workspace overrides.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/OverrideConfig"
      }
    },
    "ownership": {
      "description": "Code ownership configuration.",
      "anyOf": [
        {
          "$ref": "#/definitions/OwnershipConfig"
        },
        {
          "type": "null"
        }
      ]
    },
    "resolver": {
      "description": "Module resolver configuration.",
      "default": {
        "respectExports": true,
        "preserveSymlinks": false
      },
      "allOf": [
        {
          "$ref": "#/definitions/ResolverConfig"
        }
      ]
    },
    "rules": {
      "description": "Custom rules.",
      "anyOf": [
        {
          "$ref": "#/definitions/RulesConfig"
        },
        {
          "type": "null"
        }
      ]
    },
    "workspaces": {
      "description": "Workspace configuration.",
      "anyOf": [
        {
          "$ref": "#/definitions/WorkspacesConfig"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "definitions": {
    "AnalysisConfig": {
      "type": "object",
      "properties": {
        "boundaries": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "cycles": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "impact": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "ownership": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "unusedDependencies": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "unusedExports": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "unusedFiles": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "unusedPackages": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        }
      }
    },
    "AnalysisSeverity": {
      "description": "Severity level for analysis features.",
      "type": "string",
      "enum": [
        "off",
        "info",
        "warn",
        "error"
      ]
    },
    "EntrypointsConfig": {
      "type": "object",
      "properties": {
        "auto": {
          "description": "Auto-detect entrypoints from package.json and conventions.",
          "default": true,
          "type": "boolean"
        },
        "exclude": {
          "description": "Exclude entrypoints matching these globs.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "include": {
          "description": "Additional entrypoint globs.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "includeStories": {
          "description": "Whether to include story files as entrypoints.",
          "default": false,
          "type": "boolean"
        },
        "includeTests": {
          "description": "Whether to include test files as entrypoints.",
          "default": false,
          "type": "boolean"
        },
        "profiles": {
          "description": "Profile-specific entrypoint overrides.",
          "anyOf": [
            {
              "$ref": "#/definitions/ProfilesConfig"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "FrameworkToggle": {
      "type": "string",
      "enum": [
        "off",
        "auto",
        "on"
      ]
    },
    "FrameworksConfig": {
      "type": "object",
      "properties": {
        "angular": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "astro": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "cypress": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "docusaurus": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "jest": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "next": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "nuxt": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "nx": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "playwright": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "remix": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "storybook": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "sveltekit": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "turborepo": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "vite": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "vitepress": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "vitest": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "OverrideConfig": {
      "type": "object",
      "properties": {
        "analysis": {
          "description": "Analysis overrides.",
          "anyOf": [
            {
              "$ref": "#/definitions/AnalysisConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "entrypoints": {
          "description": "Entrypoint overrides.",
          "anyOf": [
            {
              "$ref": "#/definitions/EntrypointsConfig"
            },
            {
              "type": "null"
            }
          ]
        },
        "files": {
          "description": "File globs this override applies to.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ignore_patterns": {
          "description": "Additional ignore patterns.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "description": "Deterministic tags applied to matching files/workspaces.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workspaces": {
          "description": "Workspace names this override applies to.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "OwnershipConfig": {
      "type": "object",
      "properties": {
        "importCodeowners": {
          "default": false,
          "type": "boolean"
        },
        "teams": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": {
            "$ref": "#/definitions/TeamConfig"
          }
        },
        "unownedSeverity": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        }
      }
    },
    "PackageManager": {
      "type": "string",
      "enum": [
        "auto",
        "pnpm",
        "npm",
        "yarn",
        "bun"
      ]
    },
    "ProfilesConfig": {
      "type": "object",
      "properties": {
        "all": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "development": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "production": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ResolverConfig": {
      "type": "object",
      "properties": {
        "conditions": {
          "description": "Export conditions to use when resolving package exports.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "extensions": {
          "description": "File extensions to resolve.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preserveSymlinks": {
          "description": "Whether to preserve symlinks during resolution.",
          "default": false,
          "type": "boolean"
        },
        "respectExports": {
          "description": "Whether to respect the `exports` field in package.json.",
          "default": true,
          "type": "boolean"
        },
        "tsconfig": {
          "description": "Paths to tsconfig files.",
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "Rule": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "comment": {
          "type": [
            "string",
            "null"
          ]
        },
        "from": {
          "anyOf": [
            {
              "$ref": "#/definitions/RuleFilter"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "severity": {
          "default": "warn",
          "allOf": [
            {
              "$ref": "#/definitions/AnalysisSeverity"
            }
          ]
        },
        "to": {
          "anyOf": [
            {
              "$ref": "#/definitions/RuleFilter"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "RuleFilter": {
      "type": "object",
      "properties": {
        "dependencyKinds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "entrypointKinds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "package": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "packageNot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "path": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pathNot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "profiles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reachableFrom": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "reaches": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "tag": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tagNot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workspace": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workspaceNot": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "RulesConfig": {
      "type": "object",
      "properties": {
        "allow": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Rule"
          }
        },
        "forbidden": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Rule"
          }
        },
        "required": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Rule"
          }
        }
      }
    },
    "TeamConfig": {
      "type": "object",
      "properties": {
        "packages": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "paths": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tags": {
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "WorkspacesConfig": {
      "type": "object",
      "properties": {
        "exclude": {
          "description": "Exclude workspaces matching these patterns.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "include": {
          "description": "Include only workspaces matching these patterns.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "packageManager": {
          "description": "Package manager to use for workspace discovery.",
          "default": "auto",
          "allOf": [
            {
              "$ref": "#/definitions/PackageManager"
            }
          ]
        },
        "roots": {
          "description": "Workspace root globs (e.g. `[\"apps/*\", \"packages/*\"]`).",
          "default": [],
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}