            }
          ]
        },
        "storybook": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "svelte": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "sveltekit": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "tanstack_router": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "trigger_dev": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "turborepo": {
          "anyOf": [
