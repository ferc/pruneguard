            },
            {
              "type": "null"
            }
          ]
        },
        "playwright_test": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "qwik": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "react_router": {
          "anyOf": [
            {
              "$ref": "#/definitions/FrameworkToggle"
            },
            {
              "type": "null"
            }
          ]
        },
        "remix": {
          "anyOf": [
