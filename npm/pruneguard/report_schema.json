{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnalysisReport",
  "description": "Full analysis report from a scan.",
  "type": "object",
  "required": [
    "cwd",
    "entrypoints",
    "findings",
    "inventories",
    "profile",
    "stats",
    "summary",
    "toolVersion",
    "version"
  ],
  "properties": {
    "cwd": {
      "description": "Working directory the analysis was run from.",
      "type": "string"
    },
    "entrypoints": {
      "description": "All detected entrypoints.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/EntrypointInfo"
      }
    },
    "findings": {
      "description": "Detected findings (violations, unused items, etc.).",
      "type": "array",
      "items": {
        "$ref": "#/definitions/Finding"
      }
    },
    "inventories": {
      "description": "Inventories of discovered entities.",
      "allOf": [
        {
          "$ref": "#/definitions/Inventories"
        }
      ]
    },
    "parityScore": {
      "description": "External parity corpus score, if available.",
      "anyOf": [
        {
          "$ref": "#/definitions/ExternalParityReport"
        },
        {
          "type": "null"
        }
      ]
    },
    "profile": {
      "description": "The profile used for this analysis.",
      "type": "string"
    },
    "stats": {
      "description": "Performance statistics.",
      "allOf": [
        {
          "$ref": "#/definitions/Stats"
        }
      ]
    },
    "summary": {
      "description": "Summary counts.",
      "allOf": [
        {
          "$ref": "#/definitions/Summary"
        }
      ]
    },
    "toolVersion": {
      "description": "Version of the pruneguard tool that produced this report.",
      "type": "string"
    },
    "version": {
      "description": "Schema version for the report format.",
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    }
  },
  "definitions": {
    "ConfidenceCounts": {
      "type": "object",
      "required": [
        "high",
        "low",
        "medium"
      ],
      "properties": {
        "high": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "low": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "medium": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        }
      }
    },
    "EntrypointInfo": {
      "description": "Info about an entrypoint.",
      "type": "object",
      "required": [
        "kind",
        "path",
        "profile",
        "source"
      ],
      "properties": {
        "framework": {
          "description": "Framework that contributed this entrypoint, if any.",
          "type": [
            "string",
            "null"
          ]
        },
        "heuristic": {
          "description": "Whether this entrypoint was detected via heuristics.",
          "type": [
            "boolean",
            "null"
          ]
        },
        "kind": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "profile": {
          "type": "string"
        },
        "reason": {
          "description": "Reason this entrypoint was detected.",
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": "string"
        },
        "workspace": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "Evidence": {
      "description": "Evidence supporting a finding.",
      "type": "object",
      "required": [
        "description",
        "kind"
      ],
      "properties": {
        "description": {
          "description": "Description of this evidence.",
          "type": "string"
        },
        "file": {
          "description": "File path involved.",
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "description": "Type of evidence.",
          "type": "string"
        },
        "line": {
          "description": "Line number, if applicable.",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "minimum": 0.0
        }
      }
    },
    "ExecutionMode": {
      "description": "Execution mode for daemon/oneshot distinction.",
      "type": "string",
      "enum": [
        "oneshot",
        "daemon"
      ]
    },
    "ExternalParityCaseResult": {
      "description": "Result of a single parity case in the external report.",
      "type": "object",
      "required": [
        "family",
        "name",
        "passed",
        "passedChecks",
        "referenceTool",
        "totalChecks"
      ],
      "properties": {
        "failures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "family": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "passedChecks": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "referenceTool": {
          "type": "string"
        },
        "totalChecks": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        }
      }
    },
    "ExternalParityFamilyScore": {
      "description": "Per-family score in the external parity report.",
      "type": "object",
      "required": [
        "family",
        "passedCases",
        "pct",
        "totalCases"
      ],
      "properties": {
        "family": {
          "type": "string"
        },
        "passedCases": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "pct": {
          "type": "number",
          "format": "double"
        },
        "totalCases": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        }
      }
    },
    "ExternalParityReport": {
      "description": "External parity report from the fixture-derived corpus.",
      "type": "object",
      "required": [
        "overallPct",
        "passedCases",
        "passedChecks",
        "totalCases",
        "totalChecks"
      ],
      "properties": {
        "byFamily": {
          "description": "Per-family parity breakdown.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExternalParityFamilyScore"
          }
        },
        "byReferenceTool": {
          "description": "Per-reference-tool parity breakdown.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExternalParityToolScore"
          }
        },
        "caseResults": {
          "description": "Individual case results.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExternalParityCaseResult"
          }
        },
        "overallPct": {
          "description": "Overall parity percentage (0-100).",
          "type": "number",
          "format": "double"
        },
        "passedCases": {
          "description": "Number of fully passing cases.",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "passedChecks": {
          "description": "Number of individual checks that passed.",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "staleDeltas": {
          "description": "Stale matrix deltas (features where the hand-authored tracker disagrees with reality).",
          "type": "array",
          "items": {
            "$ref": "#/definitions/ParityStaleDelta"
          }
        },
        "totalCases": {
          "description": "Total number of parity test cases.",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "totalChecks": {
          "description": "Total number of individual checks across all cases.",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        }
      }
    },
    "ExternalParitySummary": {
      "description": "Summary of external parity score for the stats section.",
      "type": "object",
      "required": [
        "overallPct",
        "passedCases",
        "passedChecks",
        "totalCases",
        "totalChecks"
      ],
      "properties": {
        "overallPct": {
          "description": "Overall parity percentage (0-100).",
          "type": "number",
          "format": "double"
        },
        "passedCases": {
          "description": "Cases that fully passed.",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "passedChecks": {
          "description": "Individual checks that passed.",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "totalCases": {
          "description": "Total cases evaluated.",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "totalChecks": {
          "description": "Total individual checks.",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        }
      }
    },
    "ExternalParityToolScore": {
      "description": "Per-tool score in the external parity report.",
      "type": "object",
      "required": [
        "passedCases",
        "pct",
        "tool",
        "totalCases"
      ],
      "properties": {
        "passedCases": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "pct": {
          "type": "number",
          "format": "double"
        },
        "tool": {
          "type": "string"
        },
        "totalCases": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        }
      }
    },
    "FileInfo": {
      "description": "Info about a discovered file.",
      "type": "object",
      "required": [
        "kind",
        "path"
      ],
      "properties": {
        "kind": {
          "$ref": "#/definitions/FileKind"
        },
        "path": {
          "type": "string"
        },
        "role": {
          "anyOf": [
            {
              "$ref": "#/definitions/FileRole"
            },
            {
              "type": "null"
            }
          ]
        },
        "workspace": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "FileKind": {
      "type": "string",
      "enum": [
        "source",
        "test",
        "story",
        "config",
        "generated",
        "buildoutput"
      ]
    },
    "FileRole": {
      "type": "string",
      "enum": [
        "source",
        "test",
        "story",
        "fixture",
        "example",
        "template",
        "benchmark",
        "config",
        "generated",
        "buildOutput"
      ]
    },
    "Finding": {
      "description": "A single finding from analysis.",
      "type": "object",
      "required": [
        "category",
        "code",
        "confidence",
        "id",
        "message",
        "severity",
        "subject"
      ],
      "properties": {
        "actionKinds": {
          "description": "All applicable remediation action kinds.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/RemediationActionKind"
          }
        },
        "category": {
          "description": "Category of the finding.",
          "allOf": [
            {
              "$ref": "#/definitions/FindingCategory"
            }
          ]
        },
        "code": {
          "description": "Machine-readable code (e.g. `unused-export`, `cycle`, `boundary-violation`).",
          "type": "string"
        },
        "confidence": {
          "description": "Confidence level for this finding.",
          "allOf": [
            {
              "$ref": "#/definitions/FindingConfidence"
            }
          ]
        },
        "confidenceReason": {
          "description": "Human-readable reason for the confidence level assigned to this finding.",
          "type": [
            "string",
            "null"
          ]
        },
        "evidence": {
          "description": "Evidence supporting the finding.",
          "type": "array",
          "items": {
            "$ref": "#/definitions/Evidence"
          }
        },
        "frameworkContext": {
          "description": "Framework context relevant to this finding.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "id": {
          "description": "Stable deterministic ID for this finding.",
          "type": "string"
        },
        "message": {
          "description": "Human-readable message.",
          "type": "string"
        },
        "package": {
          "description": "Package this finding belongs to, if applicable.",
          "type": [
            "string",
            "null"
          ]
        },
        "precisionSource": {
          "description": "Source of precision for this finding's evidence.",
          "anyOf": [
            {
              "$ref": "#/definitions/PrecisionSource"
            },
            {
              "type": "null"
            }
          ]
        },
        "primaryActionKind": {
          "description": "Primary remediation action kind for this finding.",
          "anyOf": [
            {
              "$ref": "#/definitions/RemediationActionKind"
            },
            {
              "type": "null"
            }
          ]
        },
        "ruleName": {
          "description": "Name of the rule that produced this finding, if any.",
          "type": [
            "string",
            "null"
          ]
        },
        "severity": {
          "description": "Severity level.",
          "allOf": [
            {
              "$ref": "#/definitions/FindingSeverity"
            }
          ]
        },
        "subject": {
          "description": "The subject of the finding (file path, export name, etc.).",
          "type": "string"
        },
        "suggestion": {
          "description": "Suggested fix.",
          "type": [
            "string",
            "null"
          ]
        },
        "trustNotes": {
          "description": "Trust-related notes for this finding.",
          "type": [
            "array",
            "null"
          ],
          "items": {
            "type": "string"
          }
        },
        "workspace": {
          "description": "Workspace this finding belongs to, if applicable.",
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "FindingCategory": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "unused-export",
            "unused-file",
            "unused-package",
            "unused-dependency",
            "cycle",
            "boundary-violation",
            "ownership-violation",
            "impact"
          ]
        },
        {
          "description": "An exported class member, enum variant, or namespace member is unused.",
          "type": "string",
          "enum": [
            "unused-member"
          ]
        },
        {
          "description": "The same symbol is exported from multiple paths (barrel re-export collision).",
          "type": "string",
          "enum": [
            "duplicate-export"
          ]
        },
        {
          "description": "A dependency is imported in source code but not declared in package.json.",
          "type": "string",
          "enum": [
            "unlisted-dependency"
          ]
        },
        {
          "description": "An exported type (interface or type alias) is unused.",
          "type": "string",
          "enum": [
            "unused-type"
          ]
        }
      ]
    },
    "FindingConfidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "FindingSeverity": {
      "type": "string",
      "enum": [
        "error",
        "warn",
        "info"
      ]
    },
    "FrameworkConfidenceCounts": {
      "description": "Breakdown of framework detection confidence levels.",
      "type": "object",
      "required": [
        "exact",
        "heuristic",
        "unsupported"
      ],
      "properties": {
        "exact": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "heuristic": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "unsupported": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        }
      }
    },
    "Inventories": {
      "description": "Inventories of discovered entities.",
      "type": "object",
      "required": [
        "files",
        "packages",
        "workspaces"
      ],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/FileInfo"
          }
        },
        "packages": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PackageInfo"
          }
        },
        "workspaces": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/WorkspaceInfo"
          }
        }
      }
    },
    "PackageInfo": {
      "description": "Info about a discovered package.",
      "type": "object",
      "required": [
        "name",
        "path",
        "workspace"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "version": {
          "type": [
            "string",
            "null"
          ]
        },
        "workspace": {
          "type": "string"
        }
      }
    },
    "ParityStaleDelta": {
      "description": "A stale delta where the hand-authored parity matrix disagrees with actual test results.",
      "type": "object",
      "required": [
        "actualLevel",
        "feature",
        "matrixLevel"
      ],
      "properties": {
        "actualLevel": {
          "description": "Actual level observed from test results.",
          "type": "string"
        },
        "feature": {
          "description": "Feature or test case name.",
          "type": "string"
        },
        "matrixLevel": {
          "description": "Level claimed in the parity matrix.",
          "type": "string"
        }
      }
    },
    "PrecisionSource": {
      "description": "Source of the precision for a finding's evidence.",
      "oneOf": [
        {
          "description": "Rust static analysis only.",
          "type": "string",
          "enum": [
            "rust-static"
          ]
        },
        {
          "description": "Derived from framework-generated source maps or .d.ts files.",
          "type": "string",
          "enum": [
            "generated-map"
          ]
        },
        {
          "description": "Derived from framework config file extraction.",
          "type": "string",
          "enum": [
            "config-derived"
          ]
        },
        {
          "description": "Refined by the semantic helper binary.",
          "type": "string",
          "enum": [
            "semantic-helper"
          ]
        }
      ]
    },
    "RemediationActionKind": {
      "description": "The kind of remediation action to take.",
      "type": "string",
      "enum": [
        "delete-file",
        "delete-export",
        "remove-dependency",
        "break-cycle",
        "move-import",
        "tighten-entrypoint",
        "update-boundary-rule",
        "assign-owner",
        "split-package",
        "acknowledge-baseline"
      ]
    },
    "ReplacementFamilyScore": {
      "description": "Per-family replacement score for the weighted replacement metric.",
      "type": "object",
      "required": [
        "family",
        "passedCases",
        "score",
        "tier",
        "totalCases"
      ],
      "properties": {
        "family": {
          "description": "Family name (e.g. \"vite\", \"next\", \"jest\").",
          "type": "string"
        },
        "passedCases": {
          "description": "Passing test cases in this family.",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "score": {
          "description": "Replacement score for this family (0-100).",
          "type": "number",
          "format": "double"
        },
        "tier": {
          "description": "Tier of this family (1 or 2).",
          "type": "integer",
          "format": "uint8",
          "minimum": 0.0
        },
        "totalCases": {
          "description": "Total test cases in this family.",
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        }
      }
    },
    "Stats": {
      "description": "Performance statistics.",
      "type": "object",
      "required": [
        "affectedEntrypoints",
        "affectedFiles",
        "affectedPackages",
        "affectedScopeIncomplete",
        "baselineApplied",
        "baselineProfileMismatch",
        "cacheEntriesRead",
        "cacheEntriesWritten",
        "cacheHits",
        "cacheMisses",
        "changedFiles",
        "confidenceCounts",
        "durationMs",
        "entrypointsDetected",
        "filesCached",
        "filesDiscovered",
        "filesParsed",
        "filesResolved",
        "focusApplied",
        "focusedFiles",
        "focusedFindings",
        "fullScopeRequired",
        "graphEdges",
        "graphNodes",
        "newFindings",
        "partialScope",
        "resolvedViaExports",
        "suppressedFindings",
        "unresolvedByReason",
        "unresolvedSpecifiers"
      ],
      "properties": {
        "affectedEntrypoints": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "affectedFiles": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "affectedPackages": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "affectedScopeIncomplete": {
          "type": "boolean"
        },
        "baselineApplied": {
          "type": "boolean"
        },
        "baselineProfileMismatch": {
          "type": "boolean"
        },
        "cacheEntriesRead": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "cacheEntriesWritten": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "cacheHits": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "cacheMisses": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "changedFiles": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "compatibilityWarnings": {
          "description": "Compatibility warnings from framework detection.",
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidenceCounts": {
          "$ref": "#/definitions/ConfidenceCounts"
        },
        "durationMs": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "entrypointsDetected": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "executionMode": {
          "description": "Execution mode used for this analysis.",
          "anyOf": [
            {
              "$ref": "#/definitions/ExecutionMode"
            },
            {
              "type": "null"
            }
          ]
        },
        "externalParity": {
          "description": "External parity score summary, if available.",
          "anyOf": [
            {
              "$ref": "#/definitions/ExternalParitySummary"
            },
            {
              "type": "null"
            }
          ]
        },
        "externalParityPct": {
          "description": "External parity score percentage (0-100), if computed.",
          "type": [
            "number",
            "null"
          ],
          "format": "double"
        },
        "filesCached": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "filesDiscovered": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "filesParsed": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "filesResolved": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "focusApplied": {
          "type": "boolean"
        },
        "focusedFiles": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "focusedFindings": {
          "type": "integer",
          "format": "uint",
          "minimum": 0.0
        },
        "frameworkConfidenceCounts": {
          "description": "Framework confidence breakdown.",
          "default": {
            "exact": 0,
            "heuristic": 0,
            "unsupported": 0
          },
          "allOf": [
            {
              "$ref": "#/definitions/FrameworkConfidenceCounts"
            }
          ]
        },
        "frameworksDetected": {
