{
  "name": "pruneguard-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "pnpm -r run build",
    "build:js": "pnpm --dir apps/pruneguard build-js",
    "check:napi": "cargo check -p pruneguard --features napi",
    "test": "pnpm -r run test",
    "generate-schemas": "cargo run -p pruneguard --bin generate_schemas",
    "schemas:check": "cargo run -p pruneguard --bin generate_schemas && git diff --exit-code -- npm/pruneguard/configuration_schema.json npm/pruneguard/report_schema.json",
    "stage-release": "node scripts/stage_npm_release.mjs",
    "smoke:repos": "cargo test -p pruneguard --test parity_smoke -- --ignored --nocapture",
    "parity": "cargo test -p pruneguard --test parity_smoke -- --ignored --nocapture"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.5.1",
    "tsdown": "0.21.2",
    "typescript": "5.9.2",
    "vitest": "4.0.18"
  }
}
