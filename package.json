{
  "name": "oxgraph-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "pnpm -r run build",
    "build:js": "pnpm --dir apps/oxgraph build-js",
    "check:napi": "cargo check -p oxgraph --features napi",
    "test": "pnpm -r run test",
    "generate-schemas": "cargo run -p oxgraph --bin generate_schemas",
    "schemas:check": "cargo run -p oxgraph --bin generate_schemas && git diff --exit-code -- npm/oxgraph/configuration_schema.json npm/oxgraph/report_schema.json",
    "pack-smoke": "mkdir -p /tmp/oxgraph-pack && npm_config_cache=/tmp/oxgraph-npm-cache npm pack --prefix npm/oxgraph --pack-destination /tmp/oxgraph-pack",
    "smoke:repos": "cargo test -p oxgraph --test parity_smoke -- --ignored --nocapture",
    "parity": "cargo test -p oxgraph --test parity_smoke -- --ignored --nocapture"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.5.1",
    "tsdown": "0.21.2",
    "typescript": "5.9.2",
    "vitest": "4.0.18"
  }
}
