{
  "analysis": {
    "unusedExports": "off",
    "unusedFiles": "off",
    "unusedDependencies": "off",
    "unusedPackages": "off",
    "cycles": "off",
    "boundaries": "error",
    "ownership": "off",
    "impact": "off"
  },
  "rules": {
    "forbidden": [
      {
        "name": "reachable-from-index",
        "severity": "error",
        "from": {
          "path": ["src/app.ts"],
          "reachableFrom": ["src/index.ts"]
        },
        "to": { "path": ["src/secret.ts"] }
      }
    ]
  }
}
